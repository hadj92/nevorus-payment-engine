<?xml version="1.0" encoding="UTF-8"?>
<sequence name="CashoutMtnCiSequence" trace="enable" statistics="enable" xmlns="http://ws.apache.org/ns/synapse">
    <sequence key="GenerateMtnAccessToken"/>
    <script language="js"><![CDATA[
        var uuid = java.util.UUID.randomUUID().toString();
        mc.setVariable("referenceId", uuid);
    ]]></script>

    <variable name="subscriptionKey" value="12b5c321de6c448b8074fa5b1592dd36" type="STRING"/>
    <variable name="token" type="STRING" expression="${vars.accessToken}"/>


    <payloadFactory media-type="json">
        <format>
            {
            "amount": "${payload.amount}",
            "currency": "${payload.currency}",
            "externalId": "${payload.orderId}",
            "payer": {
            "partyIdType": "MSISDN",
            "partyId": "${payload.msisdn}"
            },
            "payerMessage": "Payment for order ${payload.orderId}",
            "payeeNote": "Cash-in transaction"
            }
        </format>
    </payloadFactory>

    <log category="INFO">
        <message>=== MTN Request Details ===</message>
    </log>
    
    <log category="INFO">
        <message>X-Reference-Id: ${vars.referenceId}</message>
    </log>
    
    <log category="INFO">
        <message>X-Target-Environment: sandbox</message>
    </log>
    
    <log category="INFO">
        <message>Ocp-Apim-Subscription-Key: ${vars.subscriptionKey}</message>
    </log>
    
    <log category="INFO">
        <message>Authorization: Bearer ${vars.token}</message>
    </log>
    
    <log category="INFO">
        <message>Request Body: ${payload}</message>
    </log>
    
    <http.post configKey="MtnCollectionConnection">
        <relativePath>/collection/v2_0/requesttowithdraw</relativePath>
        <headers>[["X-Reference-Id","${vars.referenceId}"],["X-Target-Environment","sandbox"],["Ocp-Apim-Subscription-Key","${vars.subscriptionKey}"],["Authorization","Bearer ${vars.token}"]]</headers>
        <requestBodyType>JSON</requestBodyType>
        <requestBodyJson>${payload}</requestBodyJson>
        <forceScAccepted>false</forceScAccepted>
        <disableChunking>false</disableChunking>
        <forceHttp10>false</forceHttp10>
        <noKeepAlive>false</noKeepAlive>
        <forcePostPutNobody>false</forcePostPutNobody>
        <responseVariable>mtnCashoutResponse</responseVariable>
        <overwriteBody>true</overwriteBody>
    </http.post>

    <log category="INFO">
        <message>MTN Cashout Response - Status Code: ${vars.mtnCashoutResponse.attributes.statusCode}</message>
    </log>
    
    <payloadFactory media-type="json" template-type="default">
        <format>{ "code" : "${vars.mtnCashoutResponse.attributes.statusCode}", "message" : "Succesfuly initiated"}</format>
    </payloadFactory>

</sequence>
